---
import "../styles/global.css";

export const prerender = true;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <main class="min-h-screen flex items-center justify-center px-4 py-10">
      <!-- Decorative background shapes -->
      <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
        <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-brand-400/10 blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-accent-500/5 blur-3xl"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-surface-300/10 blur-3xl"></div>
      </div>

      <section class="card w-full max-w-md p-8 sm:p-10 animate-slide-up">
        <!-- Logo -->
        <div class="flex justify-center mb-8">
          <div class="w-14 h-14 rounded-2xl bg-accent-500 flex items-center justify-center shadow-xl shadow-accent-500/20">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
        </div>

        <div class="mb-8 text-center">
          <h1 class="font-display text-2xl font-bold text-surface-900">Panel Admin</h1>
          <p class="text-surface-500 text-sm mt-2">Inicia sesión para gestionar productos.</p>
        </div>

        <form id="login-form" class="space-y-5">
          <div>
            <label for="email" class="input-label">Correo</label>
            <input id="email" name="email" type="email" autocomplete="email" class="input-field" placeholder="tu@email.com" required />
          </div>

          <div>
            <label for="password" class="input-label">Contraseña</label>
            <input id="password" name="password" type="password" autocomplete="current-password" class="input-field" placeholder="********" required />
          </div>

          <p id="login-error" class="hidden text-sm text-accent-700 bg-accent-50 border border-accent-200 rounded-xl px-4 py-3"></p>

          <button id="login-btn" type="submit" class="btn-primary w-full justify-center py-3 text-base">
            Entrar
          </button>

          <button id="recover-password-btn" type="button" class="btn-secondary w-full justify-center" onclick="recoverPassword()">
            Recuperar Contraseña
          </button>
        </form>

        <div class="mt-6 text-center">
          <a href="/" class="inline-flex items-center gap-1.5 text-brand-600 text-sm font-medium hover:text-brand-700 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Volver al catálogo
          </a>
        </div>
      </section>
    </main>

    <script>
      import { getBrowserClient } from "../lib/supabase";

      const supabase = getBrowserClient();
      const form = document.getElementById("login-form");
      const loginBtn = document.getElementById("login-btn");
      const errorEl = document.getElementById("login-error");

      async function boot() {
        const { data: { session } } = await supabase.auth.getSession();
        if (session) {
          window.location.replace("/dashboard");
        }
      }

      boot();

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const email = (document.getElementById("email") as HTMLInputElement).value.trim();
        const password = (document.getElementById("password") as HTMLInputElement).value;

        errorEl?.classList.add("hidden");
        if (errorEl) errorEl.textContent = "";

        if (!email || !password) {
          if (errorEl) {
            errorEl.textContent = "Completa correo y contraseña.";
            errorEl.classList.remove("hidden");
          }
          return;
        }

        if (loginBtn) {
          loginBtn.setAttribute("disabled", "true");
          loginBtn.textContent = "Entrando...";
        }

        const { error } = await supabase.auth.signInWithPassword({ email, password });

        if (loginBtn) {
          loginBtn.removeAttribute("disabled");
          loginBtn.textContent = "Entrar";
        }

        if (error) {
          if (errorEl) {
            errorEl.textContent = error.message;
            errorEl.classList.remove("hidden");
          }
          return;
        }

        window.location.replace("/dashboard");
      });

      async function recoverPassword() {
        const email = document.getElementById('email').value;
        if (!email) {
          alert('Por favor, ingresa tu correo electrónico para recuperar tu contraseña.');
          return;
        }

        try {
          const supabase = getBrowserClient();
          const { error } = await supabase.auth.resetPasswordForEmail(email);

          if (error) {
            alert('Hubo un error al intentar recuperar la contraseña: ' + error.message);
          } else {
            alert('Se ha enviado un correo para restablecer tu contraseña. Por favor, revisa tu bandeja de entrada.');
          }
        } catch (err) {
          console.error('Error al intentar recuperar la contraseña:', err);
          alert('Ocurrió un error inesperado. Por favor, intenta nuevamente más tarde.');
        }
      }

      async function createAdminUser() {
        const supabase = getBrowserClient();

        const { data, error } = await supabase.auth.signUp({
          email: "juan.aristizabalde@gmail.com",
          password: "12345678",
        });

        if (error) {
          console.error("Error al crear el usuario administrador:", error.message);
        } else {
          console.log("Usuario administrador creado exitosamente:", data);
        }
      }

      createAdminUser();
    </script>
  </body>
</html>
