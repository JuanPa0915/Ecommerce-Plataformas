---
// src/pages/admin/dashboard.astro
// Dashboard admin — SSR dinamico
// CRUD completo de productos con Supabase Storage para imágenes.
import { env as runtimeEnv } from "cloudflare:workers";

export const prerender = false;

const publicSupabaseUrl = runtimeEnv.PUBLIC_SUPABASE_URL || runtimeEnv.SUPABASE_URL || "";
const publicSupabaseAnonKey = runtimeEnv.PUBLIC_SUPABASE_ANON_KEY || runtimeEnv.SUPABASE_ANON_KEY || "";

import AdminLayout from "../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard — Admin">
  <Fragment slot="head">
    <meta name="public-supabase-url" content={publicSupabaseUrl} />
    <meta name="public-supabase-anon-key" content={publicSupabaseAnonKey} />
  </Fragment>

  <div
    id="runtime-env"
    data-public-supabase-url={publicSupabaseUrl}
    data-public-supabase-anon-key={publicSupabaseAnonKey}
    class="hidden"
    aria-hidden="true"
  ></div>

  <div id="root">
    <!-- Loading inicial -->
    <div id="auth-check" class="min-h-screen flex items-center justify-center">
      <div class="flex flex-col items-center gap-4">
        <div class="w-10 h-10 rounded-full border-2 border-accent-500 border-t-transparent animate-spin"></div>
        <p class="text-surface-500 text-sm">Cargando panel…</p>
      </div>
    </div>

    <!-- Dashboard (oculto hasta verificar auth) -->
    <div id="dashboard" class="hidden min-h-screen">

      <!-- Sidebar -->
      <div class="fixed inset-y-0 left-0 w-64 bg-white/80 backdrop-blur-xl border-r border-surface-200/60 z-30 hidden lg:flex flex-col">
        <div class="p-6 border-b border-surface-200/60">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-accent-500 flex items-center justify-center shadow-lg shadow-accent-500/20">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <p class="font-display font-bold text-surface-800 text-sm">Luxe Admin</p>
              <p id="user-email" class="text-surface-500 text-xs truncate max-w-[130px]"></p>
            </div>
          </div>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <button onclick="showTab('products')" class="sidebar-link active w-full text-left" data-tab="products">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            Productos
          </button>
        </nav>
        <div class="p-4 border-t border-surface-200/60">
          <a href="/" target="_blank" class="btn-ghost w-full justify-start text-sm mb-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Ver catálogo
          </a>
          <button id="logout-btn" class="btn-ghost w-full justify-start text-sm text-accent-600 hover:text-accent-700 hover:bg-accent-50">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Cerrar sesión
          </button>
        </div>
      </div>

      <!-- Mobile header -->
      <header class="lg:hidden sticky top-0 z-20 border-b border-surface-200/60 backdrop-blur-xl bg-surface-50/80 px-4 py-3 flex items-center justify-between">
        <span class="font-display font-bold text-surface-800">Luxe Admin</span>
        <div class="flex items-center gap-2">
          <a href="/" target="_blank" class="btn-ghost !p-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <button id="logout-btn-mobile" class="btn-ghost !p-2 text-accent-500">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </button>
        </div>
      </header>

      <!-- Main content -->
      <main class="lg:ml-64 p-6">

        <!-- Tab: Productos -->
        <div id="tab-products">
          <!-- Header -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
            <div>
              <h1 class="font-display text-2xl font-bold text-surface-900">Productos</h1>
              <p class="text-surface-500 text-sm mt-1"><span id="products-count">0</span> productos en total</p>
            </div>
            <button id="new-product-btn" class="btn-primary">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              Nuevo producto
            </button>
          </div>

          <!-- Search -->
          <div class="relative mb-6">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              id="admin-search"
              type="search"
              placeholder="Buscar productos..."
              class="input-field pl-10 max-w-sm"
            />
          </div>

          <!-- Loading state -->
          <div id="products-loading" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
            {Array.from({length: 6}).map(() => (
              <div class="card p-4 space-y-3">
                <div class="skeleton h-40 w-full"></div>
                <div class="skeleton h-4 w-3/4"></div>
                <div class="skeleton h-4 w-1/2"></div>
              </div>
            ))}
          </div>

          <!-- Products grid -->
          <div id="products-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
          </div>

          <!-- Empty state -->
          <div id="products-empty" class="hidden card p-12 text-center">
            <svg class="w-12 h-12 text-surface-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <p class="text-surface-700 font-medium mb-1">Sin productos</p>
            <p class="text-surface-500 text-sm mb-4">Crea tu primer producto para comenzar.</p>
            <button id="new-product-empty-btn" class="btn-primary inline-flex">Crear producto</button>
          </div>
        </div>

      </main>
    </div>
  </div>

  <!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

  <!-- ────────────────────────────────────────────────────────────────────────
       MODAL: Crear / Editar Producto
  ──────────────────────────────────────────────────────────────────────────── -->
  <div id="product-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/30 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative z-10 w-full max-w-lg card p-6 max-h-[90vh] overflow-y-auto animate-slide-up bg-white">
      <div class="flex items-center justify-between mb-6">
        <h2 id="modal-title" class="font-display text-lg font-bold text-surface-900"></h2>
        <button id="modal-close" class="btn-ghost !p-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="space-y-4">
        <input type="hidden" id="form-id" />

        <div>
          <label class="input-label">Nombre del producto *</label>
          <input id="form-name" type="text" class="input-field" placeholder="Ej: Zapatillas Premium" />
        </div>

        <div>
          <label class="input-label">Descripción</label>
          <textarea id="form-description" class="input-field resize-none h-24" placeholder="Descripción detallada del producto…"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="input-label">Precio (COP) *</label>
            <input id="form-price" type="number" min="0" step="100" class="input-field" placeholder="150000" />
          </div>
          <div>
            <label class="input-label">Stock *</label>
            <input id="form-stock" type="number" min="0" class="input-field" placeholder="10" />
          </div>
        </div>

        <div>
          <label class="input-label">Categoría</label>
          <input id="form-category" type="text" class="input-field" placeholder="Ej: Calzado, Ropa, Electrónica" list="categories-datalist" />
          <datalist id="categories-datalist"></datalist>
        </div>

        <!-- Imagen -->
        <div>
          <label class="input-label">Imagen del producto</label>

          <!-- Vista previa actual -->
          <div id="image-preview-container" class="hidden mb-3">
            <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-surface-100">
              <img id="image-preview" src="" alt="" class="w-full h-full object-contain" />
              <button
                id="remove-image"
                class="absolute top-2 right-2 btn-danger !px-2 !py-1"
                title="Eliminar imagen"
              >
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Drop zone -->
          <div
            id="drop-zone"
            class="border-2 border-dashed border-surface-300 hover:border-brand-400 rounded-xl p-6 text-center cursor-pointer transition-colors duration-200"
          >
            <div id="upload-progress" class="hidden mb-3">
              <div class="h-1.5 bg-surface-200 rounded-full overflow-hidden">
                <div id="progress-bar" class="h-full bg-gradient-to-r from-brand-400 to-accent-500 rounded-full transition-all duration-300 w-0"></div>
              </div>
              <p class="text-xs text-surface-500 mt-2">Subiendo imagen…</p>
            </div>
            <svg class="w-8 h-8 text-surface-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-surface-600 text-sm mb-1">Arrastra una imagen o haz clic</p>
            <p class="text-surface-400 text-xs">PNG, JPG, WebP hasta 5MB</p>
            <input id="image-input" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
          </div>
          <input type="hidden" id="form-image-url" />
        </div>

        <div class="flex items-center gap-3 pt-2">
          <input id="form-active" type="checkbox" checked class="w-4 h-4 rounded border-surface-300 accent-accent-500" />
          <label for="form-active" class="text-sm text-surface-600">Producto activo (visible en catálogo)</label>
        </div>

        <!-- Error del form -->
        <div id="form-error" class="hidden p-3.5 rounded-xl bg-accent-50 border border-accent-200 text-accent-700 text-sm"></div>

        <!-- Acciones -->
        <div class="flex gap-3 pt-2">
          <button id="modal-cancel" class="btn-secondary flex-1 justify-center">Cancelar</button>
          <button id="form-submit" class="btn-primary flex-1 justify-center">Guardar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL: Confirmar eliminación -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/30 backdrop-blur-sm"></div>
    <div class="relative z-10 w-full max-w-sm card p-6 animate-slide-up bg-white">
      <div class="w-12 h-12 rounded-full bg-accent-50 border border-accent-200 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </div>
      <h3 class="font-display text-lg font-bold text-surface-900 text-center mb-2">Eliminar producto</h3>
      <p class="text-surface-500 text-sm text-center mb-6">
        ¿Confirmas que deseas eliminar <strong id="delete-product-name" class="text-surface-800"></strong>? Esta acción no se puede deshacer.
      </p>
      <div class="flex gap-3">
        <button id="delete-cancel" class="btn-secondary flex-1 justify-center">Cancelar</button>
        <button id="delete-confirm" class="btn-danger flex-1 justify-center">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Eliminar
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-surface-500);
    transition: all 200ms;
    cursor: pointer;

    &:hover {
      color: var(--color-surface-800);
      background-color: var(--color-surface-100);
    }
  }
  .sidebar-link.active {
    background-color: var(--color-brand-50);
    color: var(--color-brand-700);
    border: 1px solid var(--color-brand-200);
  }
</style>



<script is:inline define:vars={{ publicSupabaseUrl, publicSupabaseAnonKey }}>
  // Inyecta variables runtime para inicializar Supabase en cliente.
  window.__PUBLIC_SUPABASE_URL__ = publicSupabaseUrl;
  window.__PUBLIC_SUPABASE_ANON_KEY__ = publicSupabaseAnonKey;
</script>

<script>
  // Logica del dashboard movida a modulo para mantener este .astro compacto
  import "../scripts/dashboard-admin";
</script>
