---
// src/pages/admin/dashboard.astro
// Dashboard admin — SSG (prerendered)
// CRUD completo de productos con Supabase Storage para imágenes.
export const prerender = true;

import AdminLayout from "../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard — Admin">
  <div id="root">
    <!-- Loading inicial -->
    <div id="auth-check" class="min-h-screen flex items-center justify-center">
      <div class="flex flex-col items-center gap-4">
        <div class="w-10 h-10 rounded-full border-2 border-brand-600 border-t-transparent animate-spin"></div>
        <p class="text-surface-500 text-sm">Cargando panel…</p>
      </div>
    </div>

    <!-- Dashboard (oculto hasta verificar auth) -->
    <div id="dashboard" class="hidden min-h-screen">

      <!-- Sidebar -->
      <div class="fixed inset-y-0 left-0 w-64 bg-surface-900/80 backdrop-blur border-r border-surface-800/60 z-30 hidden lg:flex flex-col">
        <div class="p-6 border-b border-surface-800/60">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-violet-600 flex items-center justify-center shadow-lg shadow-brand-900/50">
              <svg class="w-4.5 h-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <p class="font-display font-bold text-surface-50 text-sm">Luxe Admin</p>
              <p id="user-email" class="text-surface-500 text-xs truncate max-w-[130px]"></p>
            </div>
          </div>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <button onclick="showTab('products')" class="sidebar-link active w-full text-left" data-tab="products">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            Productos
          </button>
        </nav>
        <div class="p-4 border-t border-surface-800/60">
          <a href="/" target="_blank" class="btn-ghost w-full justify-start text-sm mb-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Ver catálogo
          </a>
          <button id="logout-btn" class="btn-ghost w-full justify-start text-sm text-red-400 hover:text-red-300 hover:bg-red-950/40">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Cerrar sesión
          </button>
        </div>
      </div>

      <!-- Mobile header -->
      <header class="lg:hidden sticky top-0 z-20 border-b border-surface-800/60 backdrop-blur-xl bg-surface-950/80 px-4 py-3 flex items-center justify-between">
        <span class="font-display font-bold text-surface-50">Luxe Admin</span>
        <div class="flex items-center gap-2">
          <a href="/" target="_blank" class="btn-ghost !p-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <button id="logout-btn-mobile" class="btn-ghost !p-2 text-red-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          </button>
        </div>
      </header>

      <!-- Main content -->
      <main class="lg:ml-64 p-6">

        <!-- Tab: Productos -->
        <div id="tab-products">
          <!-- Header -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
            <div>
              <h1 class="font-display text-2xl font-bold text-surface-50">Productos</h1>
              <p class="text-surface-500 text-sm mt-1"><span id="products-count">0</span> productos en total</p>
            </div>
            <button id="new-product-btn" class="btn-primary">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              Nuevo producto
            </button>
          </div>

          <!-- Search -->
          <div class="relative mb-6">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-500 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              id="admin-search"
              type="search"
              placeholder="Buscar productos..."
              class="input-field pl-10 max-w-sm"
            />
          </div>

          <!-- Loading state -->
          <div id="products-loading" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
            {Array.from({length: 6}).map(() => (
              <div class="card p-4 space-y-3">
                <div class="skeleton h-40 w-full"></div>
                <div class="skeleton h-4 w-3/4"></div>
                <div class="skeleton h-4 w-1/2"></div>
              </div>
            ))}
          </div>

          <!-- Products grid -->
          <div id="products-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
          </div>

          <!-- Empty state -->
          <div id="products-empty" class="hidden card p-12 text-center">
            <svg class="w-12 h-12 text-surface-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <p class="text-surface-300 font-medium mb-1">Sin productos</p>
            <p class="text-surface-500 text-sm mb-4">Crea tu primer producto para comenzar.</p>
            <button id="new-product-empty-btn" class="btn-primary inline-flex">Crear producto</button>
          </div>
        </div>

      </main>
    </div>
  </div>

  <!-- ────────────────────────────────────────────────────────────────────────
       MODAL: Crear / Editar Producto
  ──────────────────────────────────────────────────────────────────────────── -->
  <div id="product-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative z-10 w-full max-w-lg card p-6 max-h-[90vh] overflow-y-auto animate-slide-up">
      <div class="flex items-center justify-between mb-6">
        <h2 id="modal-title" class="font-display text-lg font-bold text-surface-50"></h2>
        <button id="modal-close" class="btn-ghost !p-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="space-y-4">
        <input type="hidden" id="form-id" />

        <div>
          <label class="input-label">Nombre del producto *</label>
          <input id="form-name" type="text" class="input-field" placeholder="Ej: Zapatillas Premium" />
        </div>

        <div>
          <label class="input-label">Descripción</label>
          <textarea id="form-description" class="input-field resize-none h-24" placeholder="Descripción detallada del producto…"></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="input-label">Precio (COP) *</label>
            <input id="form-price" type="number" min="0" step="100" class="input-field" placeholder="150000" />
          </div>
          <div>
            <label class="input-label">Stock *</label>
            <input id="form-stock" type="number" min="0" class="input-field" placeholder="10" />
          </div>
        </div>

        <div>
          <label class="input-label">Categoría</label>
          <input id="form-category" type="text" class="input-field" placeholder="Ej: Calzado, Ropa, Electrónica" list="categories-datalist" />
          <datalist id="categories-datalist"></datalist>
        </div>

        <!-- Imagen -->
        <div>
          <label class="input-label">Imagen del producto</label>

          <!-- Vista previa actual -->
          <div id="image-preview-container" class="hidden mb-3">
            <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-surface-800">
              <img id="image-preview" src="" alt="" class="w-full h-full object-contain" />
              <button
                id="remove-image"
                class="absolute top-2 right-2 btn-danger !px-2 !py-1"
                title="Eliminar imagen"
              >
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Drop zone -->
          <div
            id="drop-zone"
            class="border-2 border-dashed border-surface-700 hover:border-brand-600/60 rounded-xl p-6 text-center cursor-pointer transition-colors duration-200"
          >
            <div id="upload-progress" class="hidden mb-3">
              <div class="h-1.5 bg-surface-700 rounded-full overflow-hidden">
                <div id="progress-bar" class="h-full bg-gradient-to-r from-brand-500 to-violet-500 rounded-full transition-all duration-300 w-0"></div>
              </div>
              <p class="text-xs text-surface-400 mt-2">Subiendo imagen…</p>
            </div>
            <svg class="w-8 h-8 text-surface-600 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-surface-400 text-sm mb-1">Arrastra una imagen o haz clic</p>
            <p class="text-surface-600 text-xs">PNG, JPG, WebP hasta 5MB</p>
            <input id="image-input" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
          </div>
          <input type="hidden" id="form-image-url" />
        </div>

        <div class="flex items-center gap-3 pt-2">
          <input id="form-active" type="checkbox" checked class="w-4 h-4 rounded border-surface-600 accent-brand-500" />
          <label for="form-active" class="text-sm text-surface-300">Producto activo (visible en catálogo)</label>
        </div>

        <!-- Error del form -->
        <div id="form-error" class="hidden p-3.5 rounded-lg bg-red-950/60 border border-red-800/40 text-red-300 text-sm"></div>

        <!-- Acciones -->
        <div class="flex gap-3 pt-2">
          <button id="modal-cancel" class="btn-secondary flex-1 justify-center">Cancelar</button>
          <button id="form-submit" class="btn-primary flex-1 justify-center">Guardar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL: Confirmar eliminación -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative z-10 w-full max-w-sm card p-6 animate-slide-up">
      <div class="w-12 h-12 rounded-full bg-red-950/60 border border-red-800/40 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </div>
      <h3 class="font-display text-lg font-bold text-surface-50 text-center mb-2">Eliminar producto</h3>
      <p class="text-surface-400 text-sm text-center mb-6">
        ¿Confirmas que deseas eliminar <strong id="delete-product-name" class="text-surface-200"></strong>? Esta acción no se puede deshacer.
      </p>
      <div class="flex gap-3">
        <button id="delete-cancel" class="btn-secondary flex-1 justify-center">Cancelar</button>
        <button id="delete-confirm" class="btn-danger flex-1 justify-center">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          Eliminar
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .sidebar-link {
    @apply flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-surface-400
           hover:text-surface-200 hover:bg-surface-800 transition-all duration-200 cursor-pointer;
  }
  .sidebar-link.active {
    @apply bg-brand-950/60 text-brand-300 border border-brand-800/40;
  }
</style>

<script>
  import { getBrowserClient, getProductImageUrl } from "../lib/supabase";
  import type { Product } from "../lib/supabase";

  const supabase = getBrowserClient();
  let allProducts: Product[] = [];
  let deleteTargetId: string | null = null;
  let existingImagePath: string | null = null;

  // ─── Auth Guard ────────────────────────────────────────────────────────────
  async function guardAuth() {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      window.location.replace("/admin");
      return false;
    }

    document.getElementById("user-email")!.textContent = session.user.email ?? "";
    document.getElementById("auth-check")!.classList.add("hidden");
    document.getElementById("dashboard")!.classList.remove("hidden");
    return true;
  }

  // ─── Logout ────────────────────────────────────────────────────────────────
  async function handleLogout() {
    await supabase.auth.signOut();
    window.location.replace("/admin");
  }

  document.getElementById("logout-btn")?.addEventListener("click", handleLogout);
  document.getElementById("logout-btn-mobile")?.addEventListener("click", handleLogout);

  // ─── Cargar productos ──────────────────────────────────────────────────────
  async function loadProducts() {
    document.getElementById("products-loading")!.classList.remove("hidden");
    document.getElementById("products-grid")!.classList.add("hidden");
    document.getElementById("products-empty")!.classList.add("hidden");

    const { data, error, count } = await supabase
      .from("products")
      .select("*", { count: "exact" })
      .order("created_at", { ascending: false });

    document.getElementById("products-loading")!.classList.add("hidden");

    if (error) {
      (window as any).showToast?.("Error al cargar productos: " + error.message, "error");
      return;
    }

    allProducts = data ?? [];
    document.getElementById("products-count")!.textContent = String(count ?? 0);

    // Cargar categorías en el datalist
    const cats = [...new Set(allProducts.map(p => p.category).filter(Boolean))];
    const dl = document.getElementById("categories-datalist")!;
    dl.innerHTML = cats.map(c => `<option value="${c}">`).join("");

    renderProducts(allProducts);
  }

  function renderProducts(products: Product[]) {
    const grid = document.getElementById("products-grid")!;
    const empty = document.getElementById("products-empty")!;

    if (products.length === 0) {
      grid.classList.add("hidden");
      empty.classList.remove("hidden");
      return;
    }

    empty.classList.add("hidden");
    grid.innerHTML = products.map(p => `
      <div class="card p-4 group" data-id="${p.id}">
        <div class="aspect-video rounded-xl overflow-hidden bg-surface-800/60 mb-4">
          ${p.image_url
            ? `<img src="${getProductImageUrl(p.image_url)}" alt="${p.name}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />`
            : `<div class="w-full h-full flex items-center justify-center">
                <svg class="w-10 h-10 text-surface-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              </div>`
          }
        </div>
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="font-medium text-surface-100 text-sm line-clamp-2 flex-1">${p.name}</h3>
          ${p.is_active
            ? '<span class="badge-green flex-shrink-0">Activo</span>'
            : '<span class="badge-red flex-shrink-0">Inactivo</span>'
          }
        </div>
        ${p.category ? `<span class="badge-brand mb-3">${p.category}</span>` : ""}
        <div class="flex items-center justify-between mt-3 pt-3 border-t border-surface-800/60">
          <span class="font-display font-semibold text-surface-50">$${p.price.toLocaleString("es-CO")}</span>
          <span class="text-xs text-surface-500">${p.stock} en stock</span>
        </div>
        <div class="flex gap-2 mt-3">
          <button
            onclick="openEditModal('${p.id}')"
            class="btn-secondary flex-1 justify-center !py-1.5 text-xs"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            Editar
          </button>
          <button
            onclick="openDeleteModal('${p.id}', '${p.name.replace(/'/g, "\\'")}')"
            class="btn-danger flex-1 justify-center !py-1.5 text-xs"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            Eliminar
          </button>
        </div>
      </div>
    `).join("");

    grid.classList.remove("hidden");
  }

  // ─── Búsqueda en admin ─────────────────────────────────────────────────────
  document.getElementById("admin-search")?.addEventListener("input", (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase();
    const filtered = allProducts.filter(p =>
      p.name.toLowerCase().includes(q) ||
      (p.category ?? "").toLowerCase().includes(q)
    );
    renderProducts(filtered);
  });

  // ─── Modal: Nuevo producto ─────────────────────────────────────────────────
  function openNewModal() {
    document.getElementById("modal-title")!.textContent = "Nuevo producto";
    document.getElementById("form-submit")!.textContent = "Crear producto";
    clearForm();
    openModal();
  }

  document.getElementById("new-product-btn")?.addEventListener("click", openNewModal);
  document.getElementById("new-product-empty-btn")?.addEventListener("click", openNewModal);

  // ─── Modal: Editar producto ────────────────────────────────────────────────
  (window as any).openEditModal = (id: string) => {
    const p = allProducts.find(p => p.id === id);
    if (!p) return;

    document.getElementById("modal-title")!.textContent = "Editar producto";
    document.getElementById("form-submit")!.textContent = "Guardar cambios";

    (document.getElementById("form-id") as HTMLInputElement).value = p.id;
    (document.getElementById("form-name") as HTMLInputElement).value = p.name;
    (document.getElementById("form-description") as HTMLTextAreaElement).value = p.description ?? "";
    (document.getElementById("form-price") as HTMLInputElement).value = String(p.price);
    (document.getElementById("form-stock") as HTMLInputElement).value = String(p.stock);
    (document.getElementById("form-category") as HTMLInputElement).value = p.category ?? "";
    (document.getElementById("form-active") as HTMLInputElement).checked = p.is_active;
    (document.getElementById("form-image-url") as HTMLInputElement).value = p.image_url ?? "";

    existingImagePath = p.image_url;

    if (p.image_url) {
      const preview = document.getElementById("image-preview") as HTMLImageElement;
      preview.src = getProductImageUrl(p.image_url);
      document.getElementById("image-preview-container")!.classList.remove("hidden");
    } else {
      document.getElementById("image-preview-container")!.classList.add("hidden");
    }

    openModal();
  };

  // ─── Modal helpers ─────────────────────────────────────────────────────────
  function openModal() {
    document.getElementById("form-error")!.classList.add("hidden");
    document.getElementById("product-modal")!.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    document.getElementById("product-modal")!.classList.add("hidden");
    document.body.style.overflow = "";
    existingImagePath = null;
    clearForm();
  }

  function clearForm() {
    (document.getElementById("form-id") as HTMLInputElement).value = "";
    (document.getElementById("form-name") as HTMLInputElement).value = "";
    (document.getElementById("form-description") as HTMLTextAreaElement).value = "";
    (document.getElementById("form-price") as HTMLInputElement).value = "";
    (document.getElementById("form-stock") as HTMLInputElement).value = "";
    (document.getElementById("form-category") as HTMLInputElement).value = "";
    (document.getElementById("form-active") as HTMLInputElement).checked = true;
    (document.getElementById("form-image-url") as HTMLInputElement).value = "";
    (document.getElementById("image-input") as HTMLInputElement).value = "";
    document.getElementById("image-preview-container")!.classList.add("hidden");
    document.getElementById("upload-progress")!.classList.add("hidden");
    existingImagePath = null;
  }

  document.getElementById("modal-close")?.addEventListener("click", closeModal);
  document.getElementById("modal-cancel")?.addEventListener("click", closeModal);
  document.getElementById("modal-backdrop")?.addEventListener("click", closeModal);

  // ─── Upload de imagen ──────────────────────────────────────────────────────
  const dropZone = document.getElementById("drop-zone")!;
  const imageInput = document.getElementById("image-input") as HTMLInputElement;

  dropZone.addEventListener("click", () => imageInput.click());

  dropZone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropZone.classList.add("border-brand-500");
  });

  dropZone.addEventListener("dragleave", () => {
    dropZone.classList.remove("border-brand-500");
  });

  dropZone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropZone.classList.remove("border-brand-500");
    const file = e.dataTransfer?.files[0];
    if (file) handleImageFile(file);
  });

  imageInput.addEventListener("change", () => {
    const file = imageInput.files?.[0];
    if (file) handleImageFile(file);
  });

  document.getElementById("remove-image")?.addEventListener("click", () => {
    (document.getElementById("form-image-url") as HTMLInputElement).value = "";
    document.getElementById("image-preview-container")!.classList.add("hidden");
    existingImagePath = null;
  });

  async function handleImageFile(file: File) {
    if (file.size > 5 * 1024 * 1024) {
      (window as any).showToast?.("La imagen no puede superar 5MB.", "error");
      return;
    }

    const progress = document.getElementById("upload-progress")!;
    const bar = document.getElementById("progress-bar")!;
    progress.classList.remove("hidden");
    bar.style.width = "20%";

    try {
      const ext = file.name.split(".").pop();
      const path = `products/${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;

      bar.style.width = "50%";

      const { error: uploadError } = await supabase.storage
        .from("products")
        .upload(path, file, { upsert: false, contentType: file.type });

      if (uploadError) throw uploadError;

      bar.style.width = "90%";

      const { data } = supabase.storage.from("products").getPublicUrl(path);

      (document.getElementById("form-image-url") as HTMLInputElement).value = data.publicUrl;

      const preview = document.getElementById("image-preview") as HTMLImageElement;
      preview.src = data.publicUrl;
      document.getElementById("image-preview-container")!.classList.remove("hidden");

      bar.style.width = "100%";
      setTimeout(() => progress.classList.add("hidden"), 800);

      (window as any).showToast?.("Imagen subida correctamente.", "success");
    } catch (err: any) {
      progress.classList.add("hidden");
      (window as any).showToast?.("Error al subir la imagen: " + err.message, "error");
    }
  }

  // ─── Guardar producto ──────────────────────────────────────────────────────
  document.getElementById("form-submit")?.addEventListener("click", async () => {
    const id          = (document.getElementById("form-id") as HTMLInputElement).value;
    const name        = (document.getElementById("form-name") as HTMLInputElement).value.trim();
    const description = (document.getElementById("form-description") as HTMLTextAreaElement).value.trim();
    const price       = parseFloat((document.getElementById("form-price") as HTMLInputElement).value);
    const stock       = parseInt((document.getElementById("form-stock") as HTMLInputElement).value, 10);
    const category    = (document.getElementById("form-category") as HTMLInputElement).value.trim();
    const is_active   = (document.getElementById("form-active") as HTMLInputElement).checked;
    const image_url   = (document.getElementById("form-image-url") as HTMLInputElement).value || null;

    const errEl = document.getElementById("form-error")!;

    // Validación
    if (!name) { errEl.textContent = "El nombre del producto es obligatorio."; errEl.classList.remove("hidden"); return; }
    if (isNaN(price) || price < 0) { errEl.textContent = "Ingresa un precio válido."; errEl.classList.remove("hidden"); return; }
    if (isNaN(stock) || stock < 0) { errEl.textContent = "Ingresa un stock válido."; errEl.classList.remove("hidden"); return; }
    errEl.classList.add("hidden");

    const btn = document.getElementById("form-submit") as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span> Guardando…';

    const payload = { name, description, price, stock, category, is_active, image_url };

    const { error } = id
      ? await supabase.from("products").update({ ...payload, updated_at: new Date().toISOString() }).eq("id", id)
      : await supabase.from("products").insert(payload);

    btn.disabled = false;
    btn.textContent = id ? "Guardar cambios" : "Crear producto";

    if (error) {
      errEl.textContent = "Error: " + error.message;
      errEl.classList.remove("hidden");
      return;
    }

    (window as any).showToast?.(id ? "Producto actualizado." : "Producto creado.", "success");
    closeModal();
    loadProducts();
  });

  // ─── Eliminar producto ─────────────────────────────────────────────────────
  (window as any).openDeleteModal = (id: string, name: string) => {
    deleteTargetId = id;
    document.getElementById("delete-product-name")!.textContent = name;
    document.getElementById("delete-modal")!.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  };

  document.getElementById("delete-cancel")?.addEventListener("click", () => {
    document.getElementById("delete-modal")!.classList.add("hidden");
    document.body.style.overflow = "";
    deleteTargetId = null;
  });

  document.getElementById("delete-confirm")?.addEventListener("click", async () => {
    if (!deleteTargetId) return;

    const btn = document.getElementById("delete-confirm") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Eliminando…";

    const { error } = await supabase.from("products").delete().eq("id", deleteTargetId);

    btn.disabled = false;
    btn.textContent = "Eliminar";
    document.getElementById("delete-modal")!.classList.add("hidden");
    document.body.style.overflow = "";

    if (error) {
      (window as any).showToast?.("Error al eliminar: " + error.message, "error");
      return;
    }

    (window as any).showToast?.("Producto eliminado.", "success");
    deleteTargetId = null;
    loadProducts();
  });

  // ─── Tabs ──────────────────────────────────────────────────────────────────
  (window as any).showTab = (tab: string) => {
    document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.add("hidden"));
    document.getElementById(`tab-${tab}`)?.classList.remove("hidden");
    document.querySelectorAll(".sidebar-link").forEach(el => {
      el.classList.toggle("active", el.getAttribute("data-tab") === tab);
    });
  };

  // ─── Init ──────────────────────────────────────────────────────────────────
  (async () => {
    const authed = await guardAuth();
    if (authed) {
      loadProducts();
    }
  })();

  // Escuchar cambios de sesión
  supabase.auth.onAuthStateChange((event) => {
    if (event === "SIGNED_OUT") {
      window.location.replace("/admin");
    }
  });
</script>
