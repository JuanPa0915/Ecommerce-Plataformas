---
import "../styles/global.css";
import { fetchProducts, fetchCategories, getProductImageUrl } from "../lib/supabase";

export const prerender = false;

// Filtros y paginacion leidos desde la URL para mantener enlaces compartibles.
const url = new URL(Astro.request.url);
const search = url.searchParams.get("search") ?? "";
const category = url.searchParams.get("category") ?? "all";
const pageParam = Number.parseInt(url.searchParams.get("page") ?? "1", 10);
const page = Number.isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;
const pageSize = 12;

const [{ data: productsData, count, error }, categories] = await Promise.all([
  fetchProducts({ search, category, page, pageSize }),
  fetchCategories(),
]);

const products = productsData ?? [];
const productCount = count ?? 0;
const totalPages = Math.max(1, Math.ceil((count ?? 0) / pageSize));

// Conserva filtros actuales al construir URLs de paginacion.
function pageUrl(p: number) {
  const next = new URL(url);
  next.searchParams.set("page", String(p));
  return `${next.pathname}${next.search}`;
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Catálogo de Productos | Luxe E-commerce</title>
    <meta name="description" content="Explora nuestro catálogo de productos exclusivos con los mejores precios." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Top navigation bar -->
    <header class="sticky top-0 z-30 border-b border-surface-200/60 backdrop-blur-xl bg-surface-50/80">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 rounded-lg bg-accent-500 flex items-center justify-center shadow-md shadow-accent-500/20 group-hover:shadow-accent-500/30 transition-shadow">
            <svg class="w-4.5 h-4.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="font-display font-bold text-surface-800 text-lg">Luxe<span class="text-accent-500">.</span></span>
        </a>
        <a href="/admin" class="inline-flex items-center gap-2 text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Panel Admin
        </a>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-10">
      <!-- Hero section -->
      <section class="mb-10">
        <h1 class="text-4xl font-extrabold text-surface-900 tracking-tight">
          Nuestro Catálogo
        </h1>
        <p class="text-surface-500 text-base mt-2">
          {productCount} producto{productCount === 1 ? "" : "s"} disponibles para ti
        </p>
      </section>

      <!-- Search & Filters -->
      <form method="GET" action="/" class="card p-4 mb-8 flex flex-col sm:flex-row gap-3 items-end">
        <div class="flex-1">
          <label for="search-input" class="input-label">Buscar</label>
          <div class="relative">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              id="search-input"
              type="search"
              name="search"
              value={search}
              placeholder="Buscar productos..."
              class="input-field pl-10"
            />
          </div>
        </div>

        <div class="sm:w-56">
          <label for="category-select" class="input-label">Categoría</label>
          <select id="category-select" name="category" class="input-field">
            <option value="all" selected={category === "all"}>Todas las categorías</option>
            {categories.map((cat) => (
              <option value={cat} selected={category === cat}>{cat}</option>
            ))}
          </select>
        </div>

        <div class="flex gap-2">
          <button type="submit" class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Buscar
          </button>

          {(search || category !== "all") && (
            <a href="/" class="btn-secondary">Limpiar</a>
          )}
        </div>
      </form>

      {error && (
        <section class="card p-6 mb-6 border-accent-200 bg-accent-50/50">
          <p class="text-accent-700 font-semibold">Error al cargar productos</p>
          <p class="text-accent-600 text-sm mt-1">{error}</p>
        </section>
      )}

      {!error && products.length === 0 && (
        <section class="card p-12 text-center mb-6">
          <svg class="w-16 h-16 text-surface-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
          <p class="text-surface-700 font-semibold text-lg">No se encontraron productos</p>
          <p class="text-surface-500 mt-1">Intenta con otros filtros de búsqueda</p>
        </section>
      )}

      {!error && products.length > 0 && (
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {products.map((product) => (
            <a href={`/product/${product.id}`} class="card group hover:shadow-xl hover:shadow-surface-300/20 hover:border-brand-300 transition-all duration-300 overflow-hidden">
              <div class="aspect-video overflow-hidden bg-surface-100">
                <img
                  src={getProductImageUrl(product.image_url)}
                  alt={product.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <article class="p-4">
                <h2 class="font-semibold text-surface-800 group-hover:text-brand-700 transition-colors">{product.name}</h2>
                <p class="text-surface-500 text-sm mt-2 line-clamp-2">{product.description}</p>
                <div class="flex items-center justify-between mt-4 pt-3 border-t border-surface-200/60">
                  <p class="text-accent-600 font-bold text-lg">${product.price.toLocaleString("es-CO")}</p>
                  <span class="badge-brand">{product.category}</span>
                </div>
              </article>
            </a>
          ))}
        </section>
      )}

      {!error && totalPages > 1 && (
        <nav class="flex items-center justify-center gap-2 mt-10">
          {page > 1 && (
            <a href={pageUrl(page - 1)} class="btn-secondary">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              Anterior
            </a>
          )}

          {Array.from({ length: totalPages }, (_, idx) => idx + 1).map((n) => (
            <a
              href={pageUrl(n)}
              class={n === page ? "btn-primary" : "btn-secondary"}
            >
              {n}
            </a>
          ))}

          {page < totalPages && (
            <a href={pageUrl(page + 1)} class="btn-secondary">
              Siguiente
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          )}
        </nav>
      )}
    </main>

    <!-- Footer -->
    <footer class="border-t border-surface-200/60 mt-12 bg-white/40">
      <div class="max-w-6xl mx-auto px-4 py-6 text-center">
        <p class="text-surface-400 text-sm">© 2026 Luxe E-commerce. Todos los derechos reservados.</p>
      </div>
    </footer>
  </body>
</html>
