---
import "../../styles/global.css";
import { fetchProductById, getProductImageUrl } from "../../lib/supabase";

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/404");
}

const product = await fetchProductById(id);

if (!product) {
  return Astro.redirect("/404");
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{product.name} | Luxe E-commerce</title>
    <meta name="description" content={product.description} />
  </head>
  <body>
    <main class="max-w-5xl mx-auto px-4 py-12">
      <div class="mb-8">
        <a href="/" class="btn-secondary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Volver al catálogo
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Imagen -->
        <div class="card p-2 overflow-hidden aspect-square flex items-center justify-center bg-surface-900/40">
          <img
            src={getProductImageUrl(product.image_url)}
            alt={product.name}
            class="max-w-full max-h-full object-contain rounded-lg"
          />
        </div>

        <!-- Info -->
        <div class="flex flex-col justify-center">
          <div class="mb-6">
            {product.category && (
              <span class="badge-brand mb-3 uppercase tracking-widest text-[10px]">
                {product.category}
              </span>
            )}
            <h1 class="text-4xl font-bold text-surface-50 mt-2">{product.name}</h1>
            <p class="text-3xl font-bold text-brand-400 mt-4">
              ${product.price.toLocaleString("es-CO")}
            </p>
          </div>

          <div class="space-y-6">
            <div class="card p-5 bg-surface-800/20 border-surface-800/40">
              <h2 class="text-sm font-semibold uppercase text-surface-400 tracking-wider mb-2">Descripción</h2>
              <p class="text-surface-200 leading-relaxed">
                {product.description || "Sin descripción disponible para este producto."}
              </p>
            </div>

            <div class="flex items-center gap-4">
              <div class="flex-1">
                <p class="text-xs text-surface-500 uppercase font-medium mb-1">Disponibilidad</p>
                <div class="flex items-center gap-2">
                  <div class={`w-2 h-2 rounded-full ${product.stock > 0 ? 'bg-emerald-500' : 'bg-red-500'}`}></div>
                  <span class="text-sm text-surface-200">
                    {product.stock > 0 ? `${product.stock} unidades disponibles` : 'Agotado'}
                  </span>
                </div>
              </div>
              <button class="btn-primary px-8 py-3 h-fit" disabled={product.stock === 0}>
                Añadir al carrito
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
