---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Admin" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-surface-950 text-surface-100">
    <slot />
  </body>
</html>
